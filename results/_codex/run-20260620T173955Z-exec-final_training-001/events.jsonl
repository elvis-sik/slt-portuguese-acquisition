    \"sequence_length\": self.sequence_length,\n            \"batch_size\": self.batch_size,\n            \"tokens_per_step\": self.tokens_per_step,\n            \"target_tokens\": self.target_tokens,\n            \"checkpoint_tokens\": list(self.checkpoint_tokens),\n            \"learning_rate\": self.learning_rate,\n            \"weight_decay\": self.weight_decay,\n            \"optimizer\": \"AdamW\",\n            \"training_precision\": \"fp32\",\n            \"seed\": self.seed,\n            \"device\": self.device,\n            \"hourly_rate_usd\": self.hourly_rate_usd,\n            \"hard_cap_usd\": self.hard_cap_usd,\n            \"starting_cumulative_cost_usd\": self.starting_cumulative_cost_usd,\n            \"split_manifest\": str(self.split_manifest),\n            \"grammar_csv\": str(self.grammar_csv),\n            \"local_files_only\": self.local_files_only,\n            \"conditions_priority_order\": list(FINAL_CONDITIONS),\n            \"llc_selection_rule\": {\n                \"fixed_llc_checkpoint_tokens\": list(self.fixed_llc_checkpoint_tokens),\n                \"adaptive_metric\": self.adaptive_metric,\n                \"adaptive_rule\": (\n                    \"After all behavior trajectories are written and before any final LLC inspection, \"\n                    \"select the adjacent structured_pt_seed_a checkpoint pair with the largest positive \"\n                    \"change in the configured behavior metric per log-token interval; if no positive \"\n                    \"increase exists, use the largest absolute BPB decrease. Add at most those two \"\n                    \"bracketing checkpoints to the fixed set.\"\n                ),\n            },\n        }\n\n\ndef load_json(path: Path) -> Any:\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef load_jsonl(path: Path) -> list[dict[str, Any]]:\n    rows: list[dict[str, Any]] = []\n    with path.open(\"r\", encoding=\"utf-8\") as handle:\n        for line in handle:\n            if line.strip():\n                rows.append(json.loads(line))\n    return rows\n\n\ndef read_config(path: Path) -> FinalConfig:\n    raw = load_json(path)\n    training = raw[\"training\"]\n    data = raw[\"data\"]\n    cost = raw.get(\"cost\", {})\n    llc = raw[\"llc_checkpoint_selection\"]\n    return FinalConfig(\n        model=raw[\"model\"][\"id\"],\n        sequence_length=int(training[\"sequence_length\"]),\n        batch_size=int(training[\"global_batch_size\"]),\n        target_tokens=int(training[\"target_tokens\"]),\n        checkpoint_tokens=tuple(int(x) for x in training[\"checkpoint_tokens\"]),\n        learning_rate=float(training[\"learning_rate\"]),\n        weight_decay=float(training.get(\"weight_decay\", 0.0)),\n        seed=int(training[\"seed\"]),\n        device=str(training[\"device\"]),\n        hourly_rate_usd=float(cost.get(\"hourly_rate_usd\", 1.0)),\n        hard_cap_usd=float(cost.get(\"hard_cap_usd\", 50.0)),\n        starting_cumulative_cost_usd=float(cost.get(\"starting_cumulative_cost_usd\", 0.0)),\n        split_manifest=Path(data[\"split_manifest\"]),\n        grammar_csv=Path(raw[\"evaluation\"][\"grammar_pairs\"]),\n        local_files_only=bool(raw[\"model\"].get(\"local_files_only\", True)),\n        fixed_llc_checkpoint_tokens=tuple(int(x) for x in llc[\"fixed_checkpoint_tokens\"]),\n        adaptive_metric=str(llc.get(\"adaptive_metric\", \"grammar_mean_margin\")),\n    )\n\n\ndef checkpoint_plan(cfg: FinalConfig) -> list[dict[str, int]]:\n    tokens = sorted({0, *cfg.checkpoint_tokens, cfg.target_tokens})\n    plan = []\n    for target in tokens:\n        step = 0 if target == 0 else math.ceil(target / cfg.tokens_per_step)\n        plan.append(\n            {\n                \"target_tokens\": int(target),\n                \"optimizer_step\": int(step),\n                \"actual_cumulative_tokens\": int(step * cfg.tokens_per_step),\n            }\n        )\n    return plan\n\n\ndef checkpoint_name(target_tokens: int) -> str:\n    return f\"tokens_{target_tokens:09d}\"\n\n\ndef split_root_from_manifest(path: Path) -> Path:\n    return path.parent\n\n\ndef prepare_data(output_dir: Path, tokenizer: Any, cfg: FinalConfig) -> dict[str, Any]:\n    source_manifest = load_json(cfg.split_manifest)\n    source_root = split_root_from_manifest(cfg.split_manifest)\n    split_dir = output_dir / \"data_splits\"\n    split_dir.mkdir(parents=True, exist_ok=True)\n\n    split_hashes: dict[str, str] = {}\n    source_split_hashes = source_manifest.get(\"split_hashes_sha256\", {})\n    copied = (\"train.jsonl\", \"validation.jsonl\", \"sampler_reference.jsonl\")\n    for filename in copied:\n        source = source_root / filename\n        target = split_dir / filename\n        shutil.copy2(source, target)\n        split_hashes[filename] = sha256_file(target)\n        expected = source_split_hashes.get(filename)\n        if expected and expected != split_hashes[filename]:\n            raise RuntimeError(f\"Hash mismatch after freezing {filename}: {split_hashes[filename]} != {expected}\")\n\n    train_rows = load_jsonl(split_dir / \"train.jsonl\")\n    validation_rows = load_jsonl(split_dir / \"validation.jsonl\")\n    sampler_rows = load_jsonl(split_dir / \"sampler_reference.jsonl\")\n    shuffled_ids, shuffle_mapping = make_shuffled_ids(\n        train_rows,\n        tokenizer,\n        cfg.sequence_length,\n        cfg.seed + CONDITION_SEED_OFFSETS[\"shuffled_pt\"],\n    )\n    shuffled_hashes = save_final_shuffled_condition(split_dir, shuffled_ids, shuffle_mapping)\n    split_hashes.update(shuffled_hashes)\n\n    grammar_hash = sha256_file(cfg.grammar_csv)\n    leakage = {\n        \"train_validation_overlap_ids\": sorted({row[\"id\"] for row in train_rows} & {row[\"id\"] for row in validation_rows}),\n        \"train_sampler_overlap_ids\": sorted({row[\"id\"] for row in train_rows} & {row[\"id\"] for row in sampler_rows}),\n        \"validation_sampler_overlap_ids\": sorted({row[\"id\"] for row in validation_rows} & {row[\"id\"] for row in sampler_rows}),\n    }\n    manifest = {\n        \"created_utc\": utc_now(),\n        \"immutability_note\": \"Final split artifacts are content-addressed by SHA256 and must not be edited in place.\",\n        \"source_split_manifest\": str(cfg.split_manifest),\n        \"source_split_manifest_sha256\": sha256_file(cfg.split_manifest),\n        \"source_split_hashes_sha256\": {k: source_split_hashes.get(k) for k in copied},\n        \"split_sizes\": {\n            \"train\": len(train_rows),\n            \"validation\": len(validation_rows),\n            \"sampler_reference\": len(sampler_rows),\n        },\n        \"split_hashes_sha256\": split_hashes,\n        \"grammar_csv\": str(cfg.grammar_csv),\n        \"grammar_csv_sha256\": grammar_hash,\n        \"leakage_check\": leakage,\n        \"shuffled_mapping_seed\": cfg.seed + CONDITION_SEED_OFFSETS[\"shuffled_pt\"],\n        \"tokenizer_vocab_sha256\": stable_json_hash(tokenizer.get_vocab()),\n    }\n    write_json(split_dir / \"split_manifest.json\", manifest)\n    return {\n        \"manifest\": manifest,\n        \"split_dir\": split_dir,\n        \"splits\": {\n            \"train\": train_rows,\n            \"validation\": validation_rows,\n            \"sampler_reference\": sampler_rows,\n        },\n        \"shuffled_ids\": shuffled_ids,\n    }\n\n\ndef load_prepared_data(output_dir: Path, cfg: FinalConfig) -> dict[str, Any]:\n    split_dir = output_dir / \"data_splits\"\n    manifest = load_json(split_dir / \"split_manifest.json\")\n    for filename, expected_hash in manifest[\"split_hashes_sha256\"].items():\n        path = split_dir / filename\n        actual_hash = sha256_file(path)\n        if actual_hash != expected_hash:\n            raise RuntimeError(f\"Prepared data hash mismatch for {filename}: {actual_hash} != {expected_hash}\")\n    source_manifest_hash = sha256_file(cfg.split_manifest)\n    if source_manifest_hash != manifest[\"source_split_manifest_sha256\"]:\n        raise RuntimeError(\n            \"Configured source split manifest hash changed after final data freeze: \"\n            f\"{source_manifest_hash} != {manifest['source_split_manifest_sha256']}\"\n        )\n    shuffled_rows = load_jsonl(split_dir / \"train_shuffled_pt_token_ids.jsonl\")\n","exit_code":0,"status":"completed"}}
