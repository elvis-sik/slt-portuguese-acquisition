{"type":"item.completed","item":{"id":"item_26","type":"command_execution","command":"/bin/bash -lc \"sed -n '1,180p' tests/test_final_training.py && sed -n '1,160p' tests/test_recipe_search.py\"","aggregated_output":"from __future__ import annotations\n\nimport tempfile\nimport unittest\nfrom pathlib import Path\n\nfrom scripts.final_training import FinalConfig, checkpoint_name, checkpoint_plan, select_llc_checkpoints\n\n\ndef cfg(tmp: Path) -> FinalConfig:\n    return FinalConfig(\n        model=\"m\",\n        sequence_length=128,\n        batch_size=32,\n        target_tokens=1000,\n        checkpoint_tokens=(0, 1, 128, 129, 1000),\n        learning_rate=1e-4,\n        weight_decay=0.0,\n        seed=1,\n        device=\"cpu\",\n        hourly_rate_usd=1.0,\n        hard_cap_usd=50.0,\n        starting_cumulative_cost_usd=0.0,\n        split_manifest=tmp / \"split_manifest.json\",\n        grammar_csv=tmp / \"grammar.csv\",\n        local_files_only=True,\n        fixed_llc_checkpoint_tokens=(0, 128, 1000),\n        adaptive_metric=\"grammar_mean_margin\",\n    )\n\n\nclass FinalTrainingHelpersTest(unittest.TestCase):\n    def test_checkpoint_plan_is_by_target_tokens(self) -> None:\n        with tempfile.TemporaryDirectory() as td:\n            plan = checkpoint_plan(cfg(Path(td)))\n\n        self.assertEqual(plan[0], {\"target_tokens\": 0, \"optimizer_step\": 0, \"actual_cumulative_tokens\": 0})\n        self.assertEqual(plan[1][\"target_tokens\"], 1)\n        self.assertEqual(plan[1][\"optimizer_step\"], 1)\n        self.assertEqual(plan[2][\"target_tokens\"], 128)\n        self.assertEqual(plan[2][\"actual_cumulative_tokens\"], 4096)\n        self.assertEqual(plan[-1][\"target_tokens\"], 1000)\n\n    def test_checkpoint_name_is_stable(self) -> None:\n        self.assertEqual(checkpoint_name(25_000), \"tokens_000025000\")\n\n    def test_llc_selection_uses_behavior_only_bracket(self) -> None:\n        with tempfile.TemporaryDirectory() as td:\n            config = cfg(Path(td))\n        summary = {\n            \"checkpoint_plan\": [\n                {\"target_tokens\": 0},\n                {\"target_tokens\": 128},\n                {\"target_tokens\": 1000},\n            ],\n            \"evaluations\": {\n                \"tokens_000000000\": {\n                    \"grammar_margin\": {\"mean_margin\": 0.0},\n                    \"pt_validation\": {\"bpb\": 3.0},\n                },\n                \"tokens_000000128\": {\n                    \"grammar_margin\": {\"mean_margin\": 0.1},\n                    \"pt_validation\": {\"bpb\": 2.0},\n                },\n                \"tokens_000001000\": {\n                    \"grammar_margin\": {\"mean_margin\": 1.5},\n                    \"pt_validation\": {\"bpb\": 1.5},\n                },\n            },\n        }\n\n        selected = select_llc_checkpoints(config, summary)\n\n        self.assertTrue(selected[\"no_final_llc_inspected\"])\n        self.assertEqual(selected[\"adaptive_bracket_tokens\"], [128, 1000])\n        self.assertEqual(selected[\"selected_checkpoint_tokens\"], [0, 128, 1000])\n\n\nif __name__ == \"__main__\":\n    unittest.main()\nfrom __future__ import annotations\n\nimport unittest\nfrom pathlib import Path\n\nfrom scripts.recipe_search import RecipeConfig, checkpoint_plan, decide_attempt, shuffled_chunks\n\n\ndef cfg() -> RecipeConfig:\n    return RecipeConfig(\n        model=\"m\",\n        sequence_length=128,\n        batch_size=64,\n        target_tokens=1000,\n        checkpoint_tokens=(0, 500, 1000),\n        learning_rate=1e-4,\n        warmup_fraction=0.03,\n        lr_schedule=\"cosine\",\n        grad_clip=1.0,\n        weight_decay=0.01,\n        seed=7,\n        device=\"cpu\",\n        hourly_rate_usd=1.0,\n        validation_jsonl=Path(\"validation.jsonl\"),\n        grammar_csv=Path(\"grammar.csv\"),\n        local_files_only=True,\n        train_corpus=\"corpus\",\n        train_corpus_config=\"pt\",\n        max_docs=2,\n    )\n\n\nclass RecipeSearchHelpersTest(unittest.TestCase):\n    def test_checkpoint_plan_caps_at_target_steps(self) -> None:\n        plan = checkpoint_plan(cfg())\n        self.assertEqual(plan[0][\"optimizer_step\"], 0)\n        self.assertEqual(plan[-1][\"actual_cumulative_tokens\"], 8192)\n\n    def test_shuffle_is_deterministic_and_preserves_multiset(self) -> None:\n        chunks = [[1, 2, 3, 4], [5, 6, 7, 8]]\n        a = shuffled_chunks(chunks, 11)\n        b = shuffled_chunks(chunks, 11)\n        self.assertEqual(a, b)\n        self.assertEqual([sorted(x) for x in a], [sorted(x) for x in chunks])\n\n    def test_decision_requires_decrease_and_shuffled_gap(self) -> None:\n        config = cfg()\n        summaries = {\n            \"structured_pt\": {\n                \"stable\": True,\n                \"evaluations\": {\n                    \"tokens_000000000\": {\"pt_validation\": {\"bpb\": 6.0}},\n                    \"tokens_000001000\": {\"pt_validation\": {\"bpb\": 4.0}},\n                },\n            },\n            \"shuffled_pt\": {\n                \"stable\": True,\n                \"evaluations\": {\n                    \"tokens_000001000\": {\"pt_validation\": {\"bpb\": 4.5}},\n                },\n            },\n        }\n        decision = decide_attempt(config, summaries)\n        self.assertEqual(decision[\"gate_decision\"], \"proceed\")\n        self.assertTrue(decision[\"criteria\"][\"structured_pt_bpb_decreasing\"])\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n","exit_code":0,"status":"completed"}}
