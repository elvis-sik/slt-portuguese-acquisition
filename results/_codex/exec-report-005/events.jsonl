ds(TinyTrace([[2.0, 4.0], [6.0, 10.0]]), init_loss=1.0, n_beta=10.0)\n\n        self.assertEqual(len(records), 4)\n        self.assertEqual(records[0][\"running_llc\"], 10.0)\n        self.assertEqual(records[1][\"running_loss_mean\"], 3.0)\n        self.assertEqual(records[1][\"running_llc\"], 20.0)\n        self.assertEqual(records[3][\"running_loss_mean\"], 8.0)\n        self.assertEqual(records[3][\"running_llc\"], 70.0)\n\n\nif __name__ == \"__main__\":\n    unittest.main()\n","exit_code":0,"status":"completed"}}
