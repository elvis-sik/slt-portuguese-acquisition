047Z/data_splits/train.jsonl:11:{\"en\": \"Hey, honeybear, hi!\", \"id\": \"opus100_stream_000010\", \"pt\": \"Olá ursinho.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:12:{\"en\": \"For example, the social dimension of the common fisheries policy has developed favourably in recent times, but is not commensurate with the large-scale adjustments proposed by the Commission under MGP IV.\", \"id\": \"opus100_stream_000011\", \"pt\": \"Por exemplo, a abordagem social da política comum da pesca evoluiu favoravelmente nos últimos tempos, embora não esteja ainda à altura da dimensão do ajustamento proposto pela Comissão no POP IV.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:13:{\"en\": \"Yeah, try again.\", \"id\": \"opus100_stream_000012\", \"pt\": \"É? Tente de novo.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:14:{\"en\": \"They, they never told me what was in it.\", \"id\": \"opus100_stream_000013\", \"pt\": \"Eles nunca me disseram o que era.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:15:{\"en\": \"What have you done?\", \"id\": \"opus100_stream_000014\", \"pt\": \"Que fizestes de mim?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:16:{\"en\": \"I'll tell you what:\", \"id\": \"opus100_stream_000015\", \"pt\": \"O que tens feito para o Shack.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:17:{\"en\": \"Okay, so, Tommie... You were right.\", \"id\": \"opus100_stream_000016\", \"pt\": \"Então Tommie... estavas certo.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:18:{\"en\": \"Mechanism of action:\", \"id\": \"opus100_stream_000017\", \"pt\": \"Mecanismo de acção:\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:19:{\"en\": \"He doesn't deserve that.\", \"id\": \"opus100_stream_000018\", \"pt\": \"Näo o merece.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:20:{\"en\": \"Bailiff? Remove the jury.\", \"id\": \"opus100_stream_000019\", \"pt\": \"Oficial de justiça, retire o júri.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:21:{\"en\": \"Just do what she says.\", \"id\": \"opus100_stream_000020\", \"pt\": \"- Faz o que ela diz.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:22:{\"en\": \"OH, NO, COUNT ME OUT.\", \"id\": \"opus100_stream_000021\", \"pt\": \"Quem te ensinou? - A mamãe.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:23:{\"en\": \"What am I to do in Northumbria with an army of two, a nun and a rag-arse?\", \"id\": \"opus100_stream_000022\", \"pt\": \"Que farei em Nortúmbria com um exército de dois: uma freira e um cu de trapos?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:24:{\"en\": \"That's the hardest part.\", \"id\": \"opus100_stream_000023\", \"pt\": \"Isso é o mais difícil.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:25:{\"en\": \"You haven't finished the story about your grandson.\", \"id\": \"opus100_stream_000024\", \"pt\": \"Você não terminou a história do seu neto.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:26:{\"en\": \"Why did you tell me that story?\", \"id\": \"opus100_stream_000025\", \"pt\": \"Por que me contou essa história?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:27:{\"en\": \"She calls us.\", \"id\": \"opus100_stream_000026\", \"pt\": \"Ela é que nos liga.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:28:{\"en\": \"-I'll check on Epps.\", \"id\": \"opus100_stream_000027\", \"pt\": \"- Vou ter com a Epps.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:29:{\"en\": \"What is that?\", \"id\": \"opus100_stream_000028\", \"pt\": \"O que é isto?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:30:{\"en\": \"Bad tempers... and a lot of strike talk.\", \"id\": \"opus100_stream_000029\", \"pt\": \"Mau ambiente... e muitas conversas sobre greve.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:31:{\"en\": \"Here she comes.\", \"id\": \"opus100_stream_000030\", \"pt\": \"Ali vem ela.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:32:{\"en\": \"In the context of Article 10 of Directive 92/102/EEC, the Joint Veterinary Committee shall be responsible for coordination where any electronic identification systems are set up.\", \"id\": \"opus100_stream_000031\", \"pt\": \"No âmbito do artigo 10.o da Directiva 92/102/CEE, a coordenação para a eventual aplicação de dispositivos electrónicos de identificação será da competência do Comité Misto Veterinário.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:33:{\"en\": \"- You trick.\", \"id\": \"opus100_stream_000032\", \"pt\": \"Prostituis-te.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:34:{\"en\": \"What happened to your head?\", \"id\": \"opus100_stream_000033\", \"pt\": \"O que aconteceu à tua cabeça?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:35:{\"en\": \"Adopted by the Commission on 9 December.\", \"id\": \"opus100_stream_000034\", \"pt\": \"Adopção pela Comissão em 9 de Dezembro.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:36:{\"en\": \"They got all the glass out.\", \"id\": \"opus100_stream_000035\", \"pt\": \"- Sim, estou bem. Eles tiraram o vidro.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:37:{\"en\": \"That's crazy.\", \"id\": \"opus100_stream_000036\", \"pt\": \"Isso é uma loucura.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:38:{\"en\": \"Uncontrolled hypertension.\", \"id\": \"opus100_stream_000037\", \"pt\": \"Hipertensão não controlada.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:39:{\"en\": \"It would be improper for us to reveal cases which we are looking into on our own initiative and there are very good reasons therefore to stick to our policy.\", \"id\": \"opus100_stream_000038\", \"pt\": \"Seria incorrecto da nossa parte revelar casos que estamos a investigar por iniciativa própria e, portanto, temos razões muito válidas para prosseguirmos sem alterações a nossa política.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:40:{\"en\": \"List of items (3)\", \"id\": \"opus100_stream_000039\", \"pt\": \"List of items (3)\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:41:{\"en\": \"Not a bad fit.\", \"id\": \"opus100_stream_000040\", \"pt\": \"Não ficam mal.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:42:{\"en\": \"-105 200 120 a) issuing charges and redemption premiums\", \"id\": \"opus100_stream_000041\", \"pt\": \"­105 200 120 a) despesas de emissão e prémios de reembolso . . .\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:43:{\"en\": \"I've wanted to shank that little calypso kid ever since I first met him.\", \"id\": \"opus100_stream_000042\", \"pt\": \"Tenho desejado desancar aquele puto desde que o conheci.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:44:{\"en\": \"Having regard to the Treaty establishing the European Community,\", \"id\": \"opus100_stream_000043\", \"pt\": \"Tendo em conta o Tratado que institui a Comunidade Europeia,\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:45:{\"en\": \"Last night when I put the girls to bed, I told them how big your heart was.\", \"id\": \"opus100_stream_000044\", \"pt\": \"A noite passada, quando deitei as meninas, disse-lhes que tens um coração gigante.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:46:{\"en\": \"It is therefore critical to assess how a private borrower would have analysed the Obligation and the maintenance of the Obligation over time [55].\", \"id\": \"opus100_stream_000045\", \"pt\": \"É, portanto, fundamental avaliar a forma como um mutuário privado teria analisado a Obrigação e a respectiva manutenção ao longo do tempo [55].\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:47:{\"en\": \"In my view sufficient account has not been taken of this and that is why I have voted against.\", \"id\": \"opus100_stream_000046\", \"pt\": \"Penso que isto não foi suficientemente levado em conta, razão pela qual votei contra.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:48:{\"en\": \"-What is it?\", \"id\": \"opus100_stream_000047\", \"pt\": \"-O que estás a fazer?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:49:{\"en\": \"- I see the bus!\", \"id\": \"opus100_stream_000048\", \"pt\": \"- estou vendo!\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:50:{\"en\": \"Now why would Winston keep that from us?\", \"id\": \"opus100_stream_000049\", \"pt\": \"O Winston escondeu-nos isso porquê?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:51:{\"en\": \"I'm with the Crime Lab.\", \"id\": \"opus100_stream_000050\", \"pt\": \"Eu sou do CSI.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:52:{\"en\": \"I'm concerned he may have gotten hurt or...\", \"id\": \"opus100_stream_000051\", \"pt\": \"Preocupa-me que possa estar ferido, ou...\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:53:{\"en\": \"Where are the girls?\", \"id\": \"opus100_stream_000052\", \"pt\": \"Onde estão as raparigas? - Quatro horas e ainda nada.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:54:{\"en\": \"We'll bushwhack 'em good.\", \"id\": \"opus100_stream_000053\", \"pt\": \"Vão ver que rica emboscada.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:55:{\"en\": \"She's not breathing.\", \"id\": \"opus100_stream_000054\", \"pt\": \"Não está a respirar.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:56:{\"en\": \"Yeah, well...\", \"id\": \"opus100_stream_000055\", \"pt\": \"Pois, bem...\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:57:{\"en\": \"- Is that right?\", \"id\": \"opus100_stream_000056\", \"pt\": \"Esta é o Raymond.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:58:{\"en\": \"And look where you ideas got us.\", \"id\": \"opus100_stream_000057\", \"pt\": \"Olha no que deu.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:59:{\"en\": \"You've lost a lot of weight.\", \"id\": \"opus100_stream_000058\", \"pt\": \"Perdeste imenso peso.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:60:{\"en\": \"Oh, you strong.\", \"id\": \"opus100_stream_000059\", \"pt\": \"Oh, é forte.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:61:{\"en\": \"I asked you about your family.\", \"id\": \"opus100_stream_000060\", \"pt\": \"Perguntei-te sobre a tua família.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:62:{\"en\": \"That you chose to save me instead of her.\", \"id\": \"opus100_stream_000061\", \"pt\": \"Que optaste salvar-me em vez dela.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:63:{\"en\": \"How am I ever going to do great things if I'm stuck here with these silly chickens?\", \"id\": \"opus100_stream_000062\", \"pt\": \"Como vou fazer grandes coisas presa aqui...\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:64:{\"en\": \"I have no idea.\", \"id\": \"opus100_stream_000063\", \"pt\": \"Não faço ideia.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:65:{\"en\": \"Mel. this time I have something.\", \"id\": \"opus100_stream_000064\", \"pt\": \"Mel. Desta vez tenho alguma coisa.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:66:{\"en\": \"There are hundreds of names here.\", \"id\": \"opus100_stream_000065\", \"pt\": \"Estão aqui centenas de nomes.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:67:{\"en\": \"That by sleeping with a future king, you had no idea that you'd be handing over your freedom, freedom to choose your own suitor.\", \"id\": \"opus100_stream_000066\", \"pt\": \"Que dormindo com um futuro rei, não tivestes ideia de que estaríeis a entregar vossa liberdade. A liberdade de escolher vosso próprio pretendente.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:68:{\"en\": \"- I don't wanna be a money watchdog here... but if you did build everything-- I say this metaphorically-- it'd have to be done over my dead body-- metaphorically.\", \"id\": \"opus100_stream_000067\", \"pt\": \"não é que eu seja um sovina mas se construísses tudo... digo isto metaforicamente... teria que ser feito por cima do meu cadáver...metaforicamente.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:69:{\"en\": \"- I have to take this.\", \"id\": \"opus100_stream_000068\", \"pt\": \"- Tenho que atender.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:70:{\"en\": \"We'll take care of this.\", \"id\": \"opus100_stream_000069\", \"pt\": \"Nós tratamos disto.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:71:{\"en\": \"And I want you to see one card.\", \"id\": \"opus100_stream_000070\", \"pt\": \"E quero que vejas uma carta.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:72:{\"en\": \"It reminded me of when I was young and stupid.\", \"id\": \"opus100_stream_000071\", \"pt\": \"Lembrou-me de quando eu era novo e estúpido.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:73:{\"en\": \"Look at you, you look awful.\", \"id\": \"opus100_stream_000072\", \"pt\": \"Olha para ti, estás horrível.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:74:{\"en\": \"He's gonna gather my plaintiffs, scare them, and then give them a lowball offer.\", \"id\": \"opus100_stream_000073\", \"pt\": \"Vai reunir os meus queixosos, assustá-los e fazer-lhes uma proposta baixa.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:75:{\"en\": \"She wanted me to send her regards.\", \"id\": \"opus100_stream_000074\", \"pt\": \"Ela manda-lhe um abraço.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:76:{\"en\": \"I'm isolating each print according to its chemical composition.\", \"id\": \"opus100_stream_000075\", \"pt\": \"Analiso-as de acordo com a composição química.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:77:{\"en\": \"What if one of these names...?\", \"id\": \"opus100_stream_000076\", \"pt\": \"E se um destes nomes...?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:78:{\"en\": \"- You're not.\", \"id\": \"opus100_stream_000077\", \"pt\": \"Mas não manda.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:79:{\"en\": \"Sorry, Frank.\", \"id\": \"opus100_stream_000078\", \"pt\": \"Lamento, Frank.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:80:{\"en\": \"That guy crashed 10 minutes after he got in there.\", \"id\": \"opus100_stream_000079\", \"pt\": \"A paragem cardíaca ocorreu 10 minutos depois de ele chegar.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:81:{\"en\": \"And he's about to get robbed.\", \"id\": \"opus100_stream_000080\", \"pt\": \"E está prestes a ser roubado.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:82:{\"en\": \"That was completely different.\", \"id\": \"opus100_stream_000081\", \"pt\": \"- Isso foi diferente.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:83:{\"en\": \"0.99, 1.18; 42 trials and 8167 patients).\", \"id\": \"opus100_stream_000082\", \"pt\": \"0, 99 - 1, 18; 42 estudos e 8167 doentes).\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:84:{\"en\": \"Because other girls liked it and they thought it was funny. That's all.\", \"id\": \"opus100_stream_000083\", \"pt\": \"Porque as outras meninas gostaram e acharam engraçado, só isso.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:85:{\"en\": \"Merry Christmas.\", \"id\": \"opus100_stream_000084\", \"pt\": \"Feliz Natal.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:86:{\"en\": \"It matters not.\", \"id\": \"opus100_stream_000085\", \"pt\": \"Tal não importa.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:87:{\"en\": \"Oh, don't worry, honey.\", \"id\": \"opus100_stream_000086\", \"pt\": \"Não te preocupes, querido.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:88:{\"en\": \"Prepare to fire!\", \"id\": \"opus100_stream_000087\", \"pt\": \"Preparar setas!\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:89:{\"en\": \"- What's all this stuff?\", \"id\": \"opus100_stream_000088\", \"pt\": \"O que são estas coisas?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:90:{\"en\": \"(S)-N-5-[2-(2-amino-4-oxo-4,6,7,8-tetrahydro-1H-pyrimido[5,4-b][1,4]thiazin-6-yl)ethyl-2-thenoyl]-L-glutamic acid\", \"id\": \"opus100_stream_000089\", \"pt\": \"ácido (S)-N-5-[2-(2-amino-4-oxo-4,6,7,8-tetrahidro-1H-pirimido[5,4-b][1,4]tiazina-6-il)etil-2-tenoíl]-L-glutâmico\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:91:{\"en\": \"in other accommodation suitable for minors.\", \"id\": \"opus100_stream_000090\", \"pt\": \"Noutro local de alojamento que disponha de instalações adequadas a menores.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:92:{\"en\": \"- If you're mobile, keep walking.\", \"id\": \"opus100_stream_000091\", \"pt\": \"Se estiverem bem, continuem a andar.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:93:{\"en\": \"She had recovered and was off.\", \"id\": \"opus100_stream_000092\", \"pt\": \"Recuperou os sentidos e foi-se embora.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:94:{\"en\": \"Look at the date.\", \"id\": \"opus100_stream_000093\", \"pt\": \"Olhe para a data.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:95:{\"en\": \"Make out? Make sense?\", \"id\": \"opus100_stream_000094\", \"pt\": \"Conseguir fazer sentido?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/train.jsonl:96:{\"en\": \"It's just bad timing.\", \"id\": \"opus100_stream_000095\", \"pt\": \"Apenas não é o momento certo.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:1:{\"en\": \"By carrying them with him he's kept them safe.\", \"id\": \"opus100_stream_000096\", \"pt\": \"Transportando-os consigo, manteve-os a salvo.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:2:{\"en\": \"This Regulation shall be binding in its entirety and directly applicable in all Member States.\", \"id\": \"opus100_stream_000097\", \"pt\": \"O presente regulamento é obrigatório em todos os seus elementos e directamente aplicável em todos os Estados-membros.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:3:{\"en\": \"NACE 23.64: Manufacture of mortars\", \"id\": \"opus100_stream_000098\", \"pt\": \"NACE 23.64: Fabricação de argamassas\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:4:{\"en\": \"What if I had another confession to make?\", \"id\": \"opus100_stream_000099\", \"pt\": \"- E se tiver outra confissão a fazer?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:5:{\"en\": \"of 31 January 2006\", \"id\": \"opus100_stream_000100\", \"pt\": \"de 31 de Janeiro de 2006\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:6:{\"en\": \"There ain't gonna be any show tonight, or anytime soon.\", \"id\": \"opus100_stream_000101\", \"pt\": \"Não haverá espetáculo hoje à noite. Nem tão cedo haverá.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:7:{\"en\": \"What is that program?\", \"id\": \"opus100_stream_000102\", \"pt\": \"Que Programa é aquele?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:8:{\"en\": \"I'm talking about a tournament.\", \"id\": \"opus100_stream_000103\", \"pt\": \"Estou a falar de um torneio.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:9:{\"en\": \"I'm here on business.\", \"id\": \"opus100_stream_000104\", \"pt\": \"Estou aqui em negócios.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:10:{\"en\": \"He asked me what I thought I was on a scale from one to ten.\", \"id\": \"opus100_stream_000105\", \"pt\": \"Perguntou-me o que me considerava, numa escala de um a dez.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:11:{\"en\": \"Brady, Brady, Brady almighty!\", \"id\": \"opus100_stream_000106\", \"pt\": \"- Brady! \\\"Todo Poderoso\\\"!\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:12:{\"en\": \"Ilaria stays off this island.\", \"id\": \"opus100_stream_000107\", \"pt\": \"A Ilaria mantém-se longe da ilha.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:13:{\"en\": \"All right, believe it or not, the fate of the entire damn human race might depend on it.\", \"id\": \"opus100_stream_000108\", \"pt\": \"Acredites ou não, o futuro da espécie humana pode depender disso.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:14:{\"en\": \"You, my friend, are simply my insurance.\", \"id\": \"opus100_stream_000109\", \"pt\": \"Tu, meu amigo, és apenas o meu seguro.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:15:{\"en\": \"This is so cool.\", \"id\": \"opus100_stream_000110\", \"pt\": \"Isto é muito fixe.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:16:{\"en\": \"It's safer here.\", \"id\": \"opus100_stream_000111\", \"pt\": \"Aqui é mais seguro.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:17:{\"en\": \"- Thank you very much, Mrs. Aysgarth.\", \"id\": \"opus100_stream_000112\", \"pt\": \"- Muito obrigado, Sra. Aysgarth.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:18:{\"en\": \"THE COMMISSION OF THE EUROPEAN COMMUNITIES,\", \"id\": \"opus100_stream_000113\", \"pt\": \"A COMISSÃO DAS COMUNIDADES EUROPEIAS,\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:19:{\"en\": \"There will be no more information seeping out of the inn.\", \"id\": \"opus100_stream_000114\", \"pt\": \"Não haverá mais fugas de informação da estalagem.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:20:{\"en\": \"How's the ending turning out?\", \"id\": \"opus100_stream_000115\", \"pt\": \"Como é que está a ficar o final?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:21:{\"en\": \"May, remember when you jumped from here to the garage roof?\", \"id\": \"opus100_stream_000116\", \"pt\": \"May, lembras-te quando saltaste daqui para o topo da garagem?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:22:{\"en\": \"I got back here to get better.\", \"id\": \"opus100_stream_000117\", \"pt\": \"Voltei aqui para melhorar.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:23:{\"en\": \"- I'm not talking to you.\", \"id\": \"opus100_stream_000118\", \"pt\": \"Ei, não estou a falar contigo.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/validation.jsonl:24:{\"en\": \"Tell your doctor immediately, if any of the following occurs during treatment with Ciprofloxacin Bayer.\", \"id\": \"opus100_stream_000119\", \"pt\": \"Informe imediatamente o seu médico caso ocorra qualquer uma das seguintes situações durante o tratamento com Ciprofloxacina Bayer.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./infra/gcp/README.md:7:- `bootstrap_and_sync.sh`: installs basic tools, copies repository, installs Codex, and (if configured) pushes the Codex API key.\n./infra/gcp/README.md:9:- `configure_ssh_for_codex.sh`: asks gcloud to create concrete OpenSSH entries.\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:1:{\"en\": \"That's my chair.\", \"id\": \"opus100_stream_000120\", \"pt\": \"Essa é a minha cadeira.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:2:{\"en\": \"Adopted on 14 November.\", \"id\": \"opus100_stream_000121\", \"pt\": \"Adopção pela Comissão em 14 de Novembro.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:3:{\"en\": \"Almost exactly.\", \"id\": \"opus100_stream_000122\", \"pt\": \"- A minha idade.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:4:{\"en\": \"I mean, this is Area 51.\", \"id\": \"opus100_stream_000123\", \"pt\": \"Isto é a Área 51.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:5:{\"en\": \"Clearly, this opening up is not merely for the benefit of Europeans; it also involves welcoming creative artists and others from third countries.\", \"id\": \"opus100_stream_000124\", \"pt\": \"É evidente que a abertura não redunda apenas em benefício dos Europeus. Implica também dar as boas-vindas a artistas criativos e outros, oriundos de países terceiros.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:6:{\"en\": \"Set up the meeting!\", \"id\": \"opus100_stream_000125\", \"pt\": \"Marquem a reunião!\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:7:{\"en\": \"Do you even care?\", \"id\": \"opus100_stream_000126\", \"pt\": \"- Tu importas-te?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:8:{\"en\": \"With all due respect, sir, I agree with Detective Williams.\", \"id\": \"opus100_stream_000127\", \"pt\": \"Com todo o respeito, senhor, concordo com Detective Williams.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:9:{\"en\": \"- What do you think?\", \"id\": \"opus100_stream_000128\", \"pt\": \"- O que é que te parece?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:10:{\"en\": \"So she's next?\", \"id\": \"opus100_stream_000129\", \"pt\": \"Então ela é a próxima?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:11:{\"en\": \"He's breathing.\", \"id\": \"opus100_stream_000130\", \"pt\": \"- Ainda respira.\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:12:{\"en\": \"Do you know how these guys are coming back, and who's... you know... behind it?\", \"id\": \"opus100_stream_000131\", \"pt\": \"Sabe como estes indivíduos estão a voltar, e quem, sabe, está por trás disto?\", \"source\": \"Helsinki-NLP/opus-100/en-pt/train\"}\n./results/01_scientific_pilot/scientific_pilot_20260620T053047Z/data_splits/sampler_reference.jsonl:13:{\"en\": \"- Stay here with me.\", \"id\": \"opus100_stream_000132\