onfig = cfg(Path(td))\n        summary = {\n            \"checkpoint_plan\": [\n                {\"target_tokens\": 0},\n                {\"target_tokens\": 128},\n                {\"target_tokens\": 1000},\n            ],\n            \"evaluations\": {\n                \"tokens_000000000\": {\n                    \"grammar_margin\": {\"mean_margin\": 0.0},\n                    \"pt_validation\": {\"bpb\": 3.0},\n                },\n                \"tokens_000000128\": {\n                    \"grammar_margin\": {\"mean_margin\": 0.1},\n                    \"pt_validation\": {\"bpb\": 2.0},\n                },\n                \"tokens_000001000\": {\n                    \"grammar_margin\": {\"mean_margin\": 1.5},\n                    \"pt_validation\": {\"bpb\": 1.5},\n                },\n            },\n        }\n\n        selected = select_llc_checkpoints(config, summary)\n\n        self.assertTrue(selected[\"no_final_llc_inspected\"])\n        self.assertEqual(selected[\"adaptive_bracket_tokens\"], [128, 1000])\n        self.assertEqual(selected[\"selected_checkpoint_tokens\"], [0, 128, 1000])\n\n\nif __name__ == \"__main__\":\n    unittest.main()\nfrom __future__ import annotations\n\nimport tempfile\nimport unittest\nfrom pathlib import Path\n\nfrom scripts.scientific_pilot import (\n    PilotConfig,\n    grammar_sanity_checks,\n    hash_tree,\n    make_shuffled_ids,\n    split_pairs,\n    stable_json_hash,\n    tokenize_texts,\n)\n\n\nclass TinyTokenizer:\n    eos_token_id = 0\n    pad_token_id = 0\n\n    def __call__(self, text: str, **_: object) -> dict[str, list[int]]:\n        ids = [len(piece) for piece in text.split()]\n        return {\"input_ids\": ids or [0]}\n\n\nclass ScientificPilotHelpersTest(unittest.TestCase):\n    def test_split_pairs_are_ordered_and_disjoint(self) -> None:\n        rows = [{\"id\": f\"r{i}\", \"en\": f\"en {i}\", \"pt\": f\"pt {i}\"} for i in range(6)]\n\n        splits = split_pairs(rows, train_size=3, val_size=2, sampler_size=1)\n\n        self.assertEqual([row[\"id\"] for row in splits[\"train\"]], [\"r0\", \"r1\", \"r2\"])\n        self.assertEqual([row[\"id\"] for row in splits[\"validation\"]], [\"r3\", \"r4\"])\n        self.assertEqual([row[\"id\"] for row in splits[\"sampler_reference\"]], [\"r5\"])\n\n    def test_shuffled_ids_are_deterministic_and_preserve_multiset(self) -> None:\n        rows = [{\"id\": \"a\", \"pt\": \"um dois tres quatro\", \"en\": \"one two three four\"}]\n        tokenizer = TinyTokenizer()\n\n        first, first_mapping = make_shuffled_ids(rows, tokenizer, sequence_length=16, seed=7)\n        second, second_mapping = make_shuffled_ids(rows, tokenizer, sequence_length=16, seed=7)\n\n        self.assertEqual(first, second)\n        self.assertEqual(first_mapping, second_mapping)\n        original = tokenize_texts(tokenizer, [rows[0][\"pt\"]], sequence_length=16)[0]\n        self.assertEqual(sorted(first[0]), sorted(original))\n\n    def test_grammar_sanity_rejects_identical_pair(self) -> None:\n        pairs = [\n            {\n                \"id\": \"1\",\n                \"phenomenon\": \"x\",\n                \"grammatical\": \"A casa é antiga.\",\n                \"ungrammatical\": \"A casa é antiga.\",\n            }\n        ]\n\n        self.assertFalse(grammar_sanity_checks(pairs)[\"passed\"])\n\n    def test_hash_helpers_are_stable(self) -> None:\n        self.assertEqual(stable_json_hash({\"b\": 2, \"a\": 1}), stable_json_hash({\"a\": 1, \"b\": 2}))\n        with tempfile.TemporaryDirectory() as tmp:\n            root = Path(tmp)\n            (root / \"x.txt\").write_text(\"x\\n\", encoding=\"utf-8\")\n            self.assertEqual(list(hash_tree(root)), [\"x.txt\"])\n\n    def test_checkpoint_schedule_includes_start_and_end(self) -> None:\n        cfg = PilotConfig(\n            model=\"m\",\n            sequence_length=128,\n            train_size=8,\n            val_size=2,\n            sampler_size=2,\n            batch_size=4,\n       